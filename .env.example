# Observability Stack — Environment Configuration
# Copy to .env and set your values.

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# PostgreSQL exporter (if using postgres-exporter)
# POSTGRES_EXPORTER_DSN=postgresql://user:password@postgres:5432/mydb?sslmode=disable

# Redis exporter (if using redis-exporter)
# REDIS_PASSWORD=your-redis-password
